#import "siddur.typ": unit

#unit(
  order: 20,
  title-en: "Shalom Aleichem",
  title-he: "שָׁלוֹם עֲלֵיכֶם",
  kavanah: "The time after shul, walking home in the darkness of the night, was one of fear and wonder, awe and giddiness. And so it became a custom for Jews to sing these words, asking that Holy Messengers protect us as we made our way home.",
  rows: (
    (label: none, pairs: (
      (tr: "Shalom aleichem, malachei hashalom", he: "שָׁלוֹם עֲלֵיכֶם, מַלְאֲכֵי הַשָּׁלוֹם"),
      (tr: "Bo'achem l'shalom, malachei hashalom", he: "בּוֹאֲכֶם לְשָׁלוֹם, מַלְאֲכֵי הַשָּׁלוֹם"),
      (tr: "Barchuni l'shalom, malachei ha'elyon", he: "בָּרְכוּנִי לְשָׁלוֹם, מַלְאֲכֵי הָעֶלְיוֹן"),
      (tr: "B'tzetchem l'shalom, malachei hashalom", he: "בְּצֵאתְכֶם לְשָׁלוֹם, מַלְאֲכֵי הַשָּׁלוֹם"),
    )),
  ),
  translation: (
    (label: none, text: "Peace upon you, angels of peace. Enter in peace, angels of peace. Bless me in peace, angels of the Most High. Go in peace, angels of peace."),
  ),
  commentary: (
    "These \"angels of peace\" descend from a story in the Talmud (Shabbat 119b): two angels, one good and one not, accompany each person home from synagogue on Shabbat eve. If the home is ready — candles lit, table set, peace between the people in it — the good angel blesses it, and even the other must answer \"amen.\" The song is a welcome sung to unseen guests.",
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 30,
  title-en: "Yedid Nefesh",
  title-he: "יְדִיד נֶפֶשׁ",
  kavanah: "A 16th-century love song by R. Elazar Azikri of Safed — the soul chasing after Shabbat as the Beloved.",
  rows: (
    (label: "V1", pairs: (
      (tr: "Yedid nefesh, Av harachaman, meshoch avdecha el retzonecha.", he: "יְדִיד נֶפֶשׁ, אָב הָרַחֲמָן, מְשֹׁךְ עַבְדְּךָ אֶל רְצוֹנֶךָ."),
      (tr: "Yarutz avdecha kemo ayal, yishtachaveh el mul hadarecha.", he: "יָרוּץ עַבְדְּךָ כְּמוֹ אַיָּל, יִשְׁתַּחֲוֶה אֶל מוּל הֲדָרֶךָ."),
      (tr: "Ye'erav lo yedidutecha, minofet tzuf v'chol ta'am.", he: "יֶעֱרַב לוֹ יְדִידוּתֶךָ, מִנֹּפֶת צוּף וְכָל טָעַם."),
    )),
    (label: "V4", pairs: (
      (tr: "Higaleh na ufros chaviv alai, et sukkat sh'lomecha.", he: "הִגָּלֶה נָא וּפְרֹשׂ חָבִיב עָלַי, אֶת סֻכַּת שְׁלוֹמֶךָ."),
      (tr: "Ta'ir eretz mik'vodecha, nagilah v'nism'cha vach.", he: "תָּאִיר אֶרֶץ מִכְּבוֹדֶךָ, נָגִילָה וְנִשְׂמְחָה בָךְ."),
      (tr: "Maher ahuv ki va mo'ed, v'chaneinu kimei olam.", he: "מַהֵר אֱהוֹב כִּי בָא מוֹעֵד, וְחָנֵּנוּ כִּימֵי עוֹלָם."),
    )),
  ),
  translation: (
    (label: "V1", text: "soul's beloved — compassionate one — pull me toward what you want. I'll run to you like a deer, fall at the light of your face. Your love is sweeter to me than honey, than anything."),
    (label: "V4", text: "show yourself, please — spread over me, beloved, your canopy of peace. Let the whole earth shine with your presence; we'll dance and delight in you. Hurry, dear one — the time is here — be with us, like in the old days."),
  ),
  commentary: (
    "Elazar Azikri wrote Yedid Nefesh in Safed in the 1500s and recorded it in his diary as a private mystical love poem, never meant for the prayerbook. It escaped his notebook and became one of the most beloved openings of Kabbalat Shabbat — a reminder that some of our most public liturgy began as someone's secret.",
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 40,
  title-en: "Lechu Neranena",
  title-he: "לְכוּ נְרַנְּנָה",
  kavanah: "The opening call of Kabbalat Shabbat — come, sing, shout to the rock of our liberation. We cross from week into Shabbat by raising our voices together. (Psalm 95)",
  rows: (
    (label: none, pairs: (
      (tr: "Lechu n'ran'na l'Adonai, nari'a l'tzur yish'einu.", he: "לְכוּ נְרַנְּנָה לַיהוָה, נָרִיעָה לְצוּר יִשְׁעֵנוּ."),
      (tr: "N'kad'ma fanav b'todah, biz'mirot nari'a lo.", he: "נְקַדְּמָה פָנָיו בְּתוֹדָה, בִּזְמִרוֹת נָרִיעַ לוֹ."),
    )),
  ),
  translation: (
    (label: none, text: "Come, let's sing out to HaShem — shout to the rock of our liberation. Let's come before HaShem's face with thanks, raise a cry with song."),
  ),
  commentary: (
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 50,
  title-en: "Shiru L'Adonai",
  title-he: "שִׁירוּ לַיהוָה",
  kavanah: "Singing is resistance work. Joy is resilience. Coming together is resilience. (Psalm 96)",
  rows: (
    (label: none, pairs: (
      (tr: "Shiru l'Adonai shir chadash, shiru l'Adonai kol ha'aretz.", he: "שִׁירוּ לַיהוָה שִׁיר חָדָשׁ, שִׁירוּ לַיהוָה כָּל־הָאָרֶץ."),
      (tr: "Shiru l'Adonai barchu shemo, bas'ru miyom l'yom y'shu'ato.", he: "שִׁירוּ לַיהוָה בָּרְכוּ שְׁמוֹ, בַּשְּׂרוּ מִיּוֹם־לְיוֹם יְשׁוּעָתוֹ."),
      (tr: "Sapru vagoyim k'vodo, b'chol ha'amim nifle'otav.", he: "סַפְּרוּ בַגּוֹיִם כְּבוֹדוֹ, בְּכָל־הָעַמִּים נִפְלְאוֹתָיו."),
      (tr: "Ki gadol Adonai um'hulal me'od, nora hu al kol elohim.", he: "כִּי גָדוֹל יְהוָה וּמְהֻלָּל מְאֹד, נוֹרָא הוּא עַל־כָּל־אֱלֹהִים."),
      (tr: "Ki kol elohei ha'amim elilim, v'Adonai shamayim asah.", he: "כִּי כָּל־אֱלֹהֵי הָעַמִּים אֱלִילִים, וַיהוָה שָׁמַיִם עָשָׂה."),
      (tr: "Hod v'hadar l'fanav, oz v'tif'eret b'mikdasho.", he: "הוֹד־וְהָדָר לְפָנָיו, עֹז וְתִפְאֶרֶת בְּמִקְדָּשׁוֹ."),
      (tr: "Havu l'Adonai mishp'chot amim, havu l'Adonai kavod va'oz.", he: "הָבוּ לַיהוָה מִשְׁפְּחוֹת עַמִּים, הָבוּ לַיהוָה כָּבוֹד וָעֹז."),
      (tr: "Havu l'Adonai k'vod sh'mo, s'u mincha u'vo'u l'chatzrotav.", he: "הָבוּ לַיהוָה כְּבוֹד שְׁמוֹ, שְׂאוּ־מִנְחָה וּבֹאוּ לְחַצְרוֹתָיו."),
      (tr: "Hishtachavu l'Adonai b'hadrat kodesh, chilu mipanav kol ha'aretz.", he: "הִשְׁתַּחֲווּ לַיהוָה בְּהַדְרַת־קֹדֶשׁ, חִילוּ מִפָּנָיו כָּל־הָאָרֶץ."),
      (tr: "Imru vagoyim Adonai malach, af tikon tevel bal timot, yadin amim b'meisharim.", he: "אִמְרוּ בַגּוֹיִם יְהוָה מָלָךְ, אַף־תִּכּוֹן תֵּבֵל בַּל־תִּמּוֹט, יָדִין עַמִּים בְּמֵישָׁרִים."),
      (tr: "Yis'm'chu hashamayim v'tagel ha'aretz, yir'am hayam um'lo'o.", he: "יִשְׂמְחוּ הַשָּׁמַיִם וְתָגֵל הָאָרֶץ, יִרְעַם הַיָּם וּמְלֹאוֹ."),
      (tr: "Ya'aloz sadai v'chol asher bo.", he: "יַעֲלֹז שָׂדַי וְכָל־אֲשֶׁר־בּוֹ."),
    )),
  ),
  translation: (
    (label: "V1", text: "Sing a new song — all the earth, sing. Sing, bless the name; carry the good news, day after day — liberation. Tell it among the nations: HaShem's glory; among all peoples — wonders. For HaShem is great, praised beyond measure — awesome above every power."),
    (label: "V2", text: "All the gods of the nations are empty — but HaShem made the heavens. Splendor and glory before HaShem; strength and beauty in the holy place. Give to HaShem, you families of peoples — give HaShem glory and strength. Give HaShem the glory of the name; bring an offering, come into HaShem's courts."),
    (label: "V3", text: "Bow before HaShem in holy splendor — tremble, all the earth. Tell the nations: HaShem reigns! The world stands firm, unshaken — peoples judged in fairness. The heavens rejoice, the earth is glad; the sea thunders, and every creature in it. The fields exult, and all that's in them."),
  ),
  commentary: (
    "Twice in Kabbalat Shabbat we're commanded to sing a shir chadash — a \"new song\" (here and in Psalm 98). The rabbis noticed: why new? Because gratitude that only repeats itself calcifies. Every Shabbat asks for a song that has never been sung before, even to the same old melody.",
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 70,
  title-en: "Mizmor Shiru L'Adonai",
  title-he: "מִזְמוֹר שִׁירוּ לַיהוָה",
  kavanah: "Psalm 98 — a second new song. The whole world becomes a band: trumpets, shofar, rivers clapping, mountains singing together.",
  rows: (
    (label: none, pairs: (
      (tr: "Mizmor. Shiru l'Adonai shir chadash, ki nifla'ot asah,", he: "מִזְמוֹר, שִׁירוּ לַיהוָה שִׁיר חָדָשׁ, כִּי־נִפְלָאוֹת עָשָׂה,"),
      (tr: "hoshi'a lo y'mino uzroa kodsho.", he: "הוֹשִׁיעָה־לּוֹ יְמִינוֹ וּזְרוֹעַ קָדְשׁוֹ."),
      (tr: "Hodia Adonai y'shu'ato, l'einei hagoyim gilah tzidkato.", he: "הוֹדִיעַ יְהוָה יְשׁוּעָתוֹ, לְעֵינֵי הַגּוֹיִם גִּלָּה צִדְקָתוֹ."),
      (tr: "Zachar chasdo ve'emunato l'veit Yisrael.", he: "זָכַר חַסְדּוֹ וֶאֱמוּנָתוֹ לְבֵית יִשְׂרָאֵל."),
      (tr: "Ra'u chol afsei aretz et y'shu'at Eloheinu.", he: "רָאוּ כָל־אַפְסֵי־אָרֶץ אֵת יְשׁוּעַת אֱלֹהֵינוּ."),
      (tr: "Hariu l'Adonai kol ha'aretz, pitzchu v'ran'nu v'zameiru.", he: "הָרִיעוּ לַיהוָה כָּל־הָאָרֶץ, פִּצְחוּ וְרַנְּנוּ וְזַמֵּרוּ."),
      (tr: "Zamru l'Adonai b'chinor, b'chinor v'kol zimrah.", he: "זַמְּרוּ לַיהוָה בְּכִנּוֹר, בְּכִנּוֹר וְקוֹל זִמְרָה."),
      (tr: "Ba'chatzotzrot v'kol shofar, hariu lifnei hamelech Adonai.", he: "בַּחֲצֹצְרוֹת וְקוֹל שׁוֹפָר, הָרִיעוּ לִפְנֵי הַמֶּלֶךְ יְהוָה."),
      (tr: "Yir'am hayam um'lo'o, tevel v'yoshvei vah.", he: "יִרְעַם הַיָּם וּמְלֹאוֹ, תֵּבֵל וְיֹשְׁבֵי בָהּ."),
      (tr: "N'harot yimcha'u chaf, yachad harim y'raneinu.", he: "נְהָרוֹת יִמְחֲאוּ־כָף, יַחַד הָרִים יְרַנֵּנוּ."),
      (tr: "Lifnei Adonai, ki va lishpot ha'aretz,", he: "לִפְנֵי־יְהוָה כִּי בָא לִשְׁפֹּט הָאָרֶץ,"),
      (tr: "yishpot tevel b'tzedek, v'amim b'meisharim.", he: "יִשְׁפֹּט־תֵּבֵל בְּצֶדֶק, וְעַמִּים בְּמֵישָׁרִים."),
    )),
  ),
  translation: (
    (label: "V1", text: "A psalm. Sing HaShem a new song — wonders have been done. HaShem's right hand, holy arm — liberation. HaShem made the liberation known; before the eyes of the nations — justice revealed. HaShem remembered love and faithfulness to the house of Israel."),
    (label: "V2", text: "All the ends of the earth have seen HaShem's liberation. All the earth — shout for HaShem — break open, sing, play on. Sing with the harp — harp and the sound of song. With trumpets, with the sound of the shofar — raise a cry before the sovereign."),
    (label: "V3", text: "The sea thunders, and everything in it — the world and all who live in it. Rivers clap their hands; mountains sing together. Before HaShem, who comes to set the earth right — judging the world in justice, peoples in fairness."),
  ),
  commentary: (
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 90,
  title-en: "Mizmor L'David",
  title-he: "מִזְמוֹר לְדָוִד",
  kavanah: "A psalm of the desert — a tribal cry from our nomadic ancestors gazing at the stars, their feet in the sand, howling at the storm. (Psalm 29)",
  rows: (
    (label: none, pairs: (
      (tr: "Mizmor l'David. Havu l'Adonai b'nei elim, havu l'Adonai kavod va'oz.", he: "מִזְמוֹר לְדָוִד. הָבוּ לַיהוָה בְּנֵי אֵלִים, הָבוּ לַיהוָה כָּבוֹד וָעֹז."),
      (tr: "Havu l'Adonai k'vod sh'mo, hishtachavu l'Adonai b'hadrat kodesh.", he: "הָבוּ לַיהוָה כְּבוֹד שְׁמוֹ, הִשְׁתַּחֲווּ לַיהוָה בְּהַדְרַת־קֹדֶשׁ."),
      (tr: "Kol Adonai al hamayim, el hakavod hir'im, Adonai al mayim rabim.", he: "קוֹל יְהוָה עַל־הַמָּיִם, אֵל־הַכָּבוֹד הִרְעִים, יְהוָה עַל־מַיִם רַבִּים."),
      (tr: "Kol Adonai ba'koach, kol Adonai behadar.", he: "קוֹל־יְהוָה בַּכֹּחַ, קוֹל יְהוָה בֶּהָדָר."),
      (tr: "Kol Adonai shover arazim, va'y'shaber Adonai et arzei ha'Levanon.", he: "קוֹל יְהוָה שֹׁבֵר אֲרָזִים, וַיְשַׁבֵּר יְהוָה אֶת־אַרְזֵי הַלְּבָנוֹן."),
      (tr: "Va'yarkidem k'mo egel, Levanon v'Siryon k'mo ven r'emim.", he: "וַיַּרְקִידֵם כְּמוֹ־עֵגֶל, לְבָנוֹן וְשִׂרְיֹן כְּמוֹ בֶן־רְאֵמִים."),
      (tr: "Kol Adonai chotzev lahavot eish.", he: "קוֹל־יְהוָה חֹצֵב לַהֲבוֹת אֵשׁ."),
      (tr: "Kol Adonai yachil midbar, yachil Adonai midbar Kadesh.", he: "קוֹל יְהוָה יָחִיל מִדְבָּר, יָחִיל יְהוָה מִדְבַּר קָדֵשׁ."),
      (tr: "Kol Adonai y'cholel ayalot va'yechesof y'arot, u'v'heichalo kulo omer kavod.", he: "קוֹל יְהוָה יְחוֹלֵל אַיָּלוֹת וַיֶּחֱשֹׂף יְעָרוֹת, וּבְהֵיכָלוֹ כֻּלּוֹ אֹמֵר כָּבוֹד."),
      (tr: "Adonai lamabul yashav, va'yeshev Adonai melech l'olam.", he: "יְהוָה לַמַּבּוּל יָשָׁב, וַיֵּשֶׁב יְהוָה מֶלֶךְ לְעוֹלָם."),
      (tr: "Adonai oz l'amo yiten, Adonai y'varech et amo vashalom.", he: "יְהוָה עֹז לְעַמּוֹ יִתֵּן, יְהוָה יְבָרֵךְ אֶת־עַמּוֹ בַשָּׁלוֹם."),
    )),
  ),
  translation: (
    (label: "V1", text: "A David song. You children of the gods — give to HaShem — give weight, give strength. Give the weight of the name; fall before HaShem in sacred trembling. HaShem's voice on the waters — the heavy one thunders — HaShem over the many waters."),
    (label: "V2", text: "HaShem's voice — force. HaShem's voice — splendor. HaShem's voice shatters cedars — HaShem shatters the cedars of Lebanon. And makes them dance like a calf — Lebanon and Sirion leap like the young wild ox."),
    (label: "V3", text: "HaShem's voice splits fire into flames. HaShem's voice — the wilderness writhes; HaShem shakes the wilderness of Kadesh. HaShem's voice sends the deer into labor, strips the forests bare — and in HaShem's shrine, all of it cries: kavod."),
    (label: "Coda", text: "HaShem sat above the flood — and stays, present through all time. HaShem gives strength to the people — HaShem blesses the people with peace."),
  ),
  commentary: (
    "Psalm 29 names the divine voice — kol HaShem — seven times, a drumbeat that many read as the seven days of creation folded into a thunderstorm. Kabbalists paired it with the seven times we might otherwise say a name aloud, and gave it to Shabbat as the storm that clears the air before rest.",
  ),
  hebrew-font: "Ezra SIL",
)

#unit(
  order: 110,
  title-en: "L'cha Dodi",
  title-he: "לְכָה דוֹדִי",
  kavanah: "A wedding poem by the mystics of Safed. They would dress in white and walk out to the fields to greet Shabbat like a bride, as the sun set over the mountains.",
  rows: (
    (label: "Refrain", pairs: (
      (tr: "Lecha dodi likrat kallah, p'nei Shabbat n'kab'la.", he: "לְכָה דוֹדִי לִקְרַאת כַּלָּה, פְּנֵי שַׁבָּת נְקַבְּלָה."),
    )),
    (label: "Shamor v'zachor", pairs: (
      (tr: "Shamor v'zachor b'dibur echad, hishmi'anu El ham'yuchad.", he: "שָׁמוֹר וְזָכוֹר בְּדִבּוּר אֶחָד, הִשְׁמִיעָנוּ אֵל הַמְיֻחָד."),
      (tr: "Adonai echad u'shmo echad, l'shem u'l'tif'eret v'li't'hilah.    (L'cha…)", he: "יְהוָה אֶחָד וּשְׁמוֹ אֶחָד, לְשֵׁם וּלְתִפְאֶרֶת וְלִתְהִלָּה.    (לְכָה…)"),
    )),
    (label: "Likrat Shabbat", pairs: (
      (tr: "Likrat Shabbat l'chu v'nelcha, ki hi m'kor hab'racha.", he: "לִקְרַאת שַׁבָּת לְכוּ וְנֵלְכָה, כִּי הִיא מְקוֹר הַבְּרָכָה."),
      (tr: "Merosh mikedem n'sucha, sof ma'aseh b'machashava t'chila.    (L'cha…)", he: "מֵרֹאשׁ מִקֶּדֶם נְסוּכָה, סוֹף מַעֲשֶׂה בְּמַחֲשָׁבָה תְּחִלָּה.    (לְכָה…)"),
    )),
    (label: "Hit'oreri", pairs: (
      (tr: "Hit'oreri, hit'oreri, ki va orech kumi ori.", he: "הִתְעוֹרְרִי הִתְעוֹרְרִי, כִּי בָא אוֹרֵךְ קוּמִי אוֹרִי."),
      (tr: "Uri, uri, shir dabeiri, k'vod Adonai alayich nigla.    (L'cha…)", he: "עוּרִי עוּרִי שִׁיר דַּבֵּרִי, כְּבוֹד יְהוָה עָלַיִךְ נִגְלָה.    (לְכָה…)"),
    )),
    (label: "Yamin usmol", pairs: (
      (tr: "Yamin usmol tif'rotzi, v'et Adonai ta'aritzi.", he: "יָמִין וּשְׂמֹאל תִּפְרֹצִי, וְאֶת יְהוָה תַּעֲרִיצִי."),
      (tr: "Al yad ish ben Partzi, v'nismecha v'nagilah.    (L'cha…)", he: "עַל יַד אִישׁ בֶּן פַּרְצִי, וְנִשְׂמְחָה וְנָגִילָה.    (לְכָה…)"),
    )),
    (label: "Bo'i v'shalom", pairs: (
      (tr: "Bo'i v'shalom ateret ba'ala, gam b'simcha uv'tzahala.", he: "בּוֹאִי בְשָׁלוֹם עֲטֶרֶת בַּעְלָהּ, גַּם בְּשִׂמְחָה וּבְצָהֳלָה."),
      (tr: "Toch emunei am segula, bo'i chala, bo'i chala.    (L'cha…)", he: "תּוֹךְ אֱמוּנֵי עַם סְגֻלָּה, בּוֹאִי כַלָּה, בּוֹאִי כַלָּה.    (לְכָה…)"),
    )),
  ),
  translation: (
    (label: "Refrain", text: "Come, beloved, to greet the bride — let's welcome the face of Shabbat."),
    (label: "Shamor v'zachor", text: "\"Protect\" and \"remember\" — one word, one breath — the One let us hear it. HaShem is one, and the Name is one — for naming, for splendor, for praise."),
    (label: "Likrat Shabbat", text: "Come, let's go toward Shabbat — she is the source of blessing. Poured out from time's beginning: last to be made, first to be imagined."),
    (label: "Hit'oreri", text: "Wake up, wake up — your light has come — rise, shine. Awake, awake — break into song — HaShem's radiance breaks open on you."),
    (label: "Yamin usmol", text: "Right and left you will burst through; it is HaShem you will adore. Through the one who breaks through — we will rejoice, we will be glad."),
    (label: "Bo'i v'shalom", text: "Come in peace, crown of her beloved — with joy, with jubilation. Into the faithful, the treasured people — come, bride; come, bride."),
  ),
  commentary: (
    "L'cha Dodi was written by Shlomo HaLevi Alkabetz in 16th-century Safed, where Kabbalists would walk into the fields at dusk on Friday to greet Shabbat as a bride. The poem is an acrostic: the first letters of its verses spell out שלמה הלוי, the poet signing his own name inside the prayer.",
    "The refrain's dodi — \"my beloved\" — is borrowed straight from the Song of Songs. Kabbalat Shabbat takes the Bible's most unabashed love poetry and points it at time itself: Shabbat as the beloved we've been waiting all week to meet.",
  ),
  hebrew-font: "Ezra SIL",
)
